#!/usr/bin/env bash
# direnv: md_on_kitty プロジェクト環境
#
# python-cairo / python-gobject はシステムパッケージなので
# --system-site-packages 付き venv を使う必要がある。
# 標準の "layout python" はそのオプションを渡せないため手動管理する。

VENV_DIR="$PWD/.venv"

# venv が無ければ作成
if [[ ! -d "$VENV_DIR" ]]; then
    echo "direnv: venv を作成しています ($VENV_DIR) ..."
    python3 -m venv --system-site-packages "$VENV_DIR"
fi

# venv をアクティベート
source "$VENV_DIR/bin/activate"

# pip パッケージが未インストールなら入れる（.installed フラグで管理）
if [[ ! -f "$VENV_DIR/.installed" ]]; then
    echo "direnv: pip パッケージをインストールしています ..."
    pip install --quiet mistune pillow watchfiles wcwidth pygments
    touch "$VENV_DIR/.installed"
fi
